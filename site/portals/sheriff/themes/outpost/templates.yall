      PAGECOUNT:
        - "BADGE::PAGE_COUNT"
      THEMESWITCHER:
        - "BRINDLE::THEMESWITCHER"
      REPO:
        - "BADGE::REPO"

      HEADER_NAV:
        - "SCOUT::header_DROPDOWN"
      SEARCH:
